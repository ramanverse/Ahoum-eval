# =============================================================================
# Ahoum Conversation Evaluation — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is gitignored — never commit real secrets.
# =============================================================================

# Optional: Hugging Face API token for downloading private/gated LLM models
# Required only for llm or hybrid scoring modes.
# Get yours at: https://huggingface.co/settings/tokens
HF_TOKEN=

# Scoring mode used by the API: feature | llm | hybrid
# 'feature' is fastest (no GPU needed); 'llm'/'hybrid' require HF_TOKEN + GPU
AHOUM_SCORING_MODE=feature

# Environment tag (development | production)
AHOUM_ENV=development
